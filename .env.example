# Worker → Supabase (one database for all tenants)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Optional global gate (if unset, per-project keys may still apply)
# WORKER_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
# Gemini embeddings output dim may differ; this repo truncates to EMBEDDING_DIMENSION for pgvector compatibility.
GEMINI_API_KEY=
EMBEDDING_DIMENSION=1536

# Chat LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0.2
GEMINI_LLM_MODEL=gemini-3.1-flash-lite-preview
GEMINI_LLM_TEMPERATURE=0.2

# Optional fallbacks / keys (keep commented if using Gemini exclusively)
# OPENAI_API_KEY=
# OPENAI_LLM_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=
# DEEPSEEK_LLM_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Logging: never enable in production with real user text
# LOG_PII=true
# LOG_LEVEL=INFO

# --- Example tenant: prefix = GREATRX (project_id "greatrx" in JSON) ---
GREATRX_VECTOR_RPC=match_documents
# Must be a table with columns: task, external_ref, interpretation, metadata, docs_used, confidence, model, processing_time_ms
GREATRX_INTERPRETATIONS_TABLE=interpretations
GREATRX_FAILED_RUNS_TABLE=interpretation_failures
# Optional: /api/rag/run-interpret loads rows keyed by issue_group_id (tickets, comments, etc.)
# GREATRX_ISSUE_GROUP_SOURCE_TABLE=tickets
# GREATRX_ISSUE_GROUP_ID_COLUMN=issue_group_id
# GREATRX_ISSUE_GROUP_ORDER_COLUMN=id
# GREATRX_ISSUE_GROUP_TEXT_COLUMNS=title,description,status
# Legacy single-column table (default table name issue_group_comments, column body):
# GREATRX_ISSUE_GROUP_COMMENTS_TABLE=issue_group_comments
# GREATRX_COMMENT_BODY_COLUMN=body
GREATRX_DEFAULT_INSTRUCTIONS=Answer clearly for support agents. Cite uncertainty when context is thin.
# Optional metadata for operators (not read by worker for retrieval)
GREATRX_DOCS_TABLE=your_docs
GREATRX_DOCS_CONTENT_COLUMN=content
GREATRX_DOCS_EMBEDDING_COLUMN=embedding
# GREATRX_WORKER_API_KEY=tenant-specific-bearer-if-no-global-key
